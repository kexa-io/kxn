    "persistent_volume": {
      "provider": "kubernetes",
      "data_source": "kubernetes_resources",
      "extra": { "api_version": "v1", "kind": "PersistentVolume" }
    },
    "persistent_volume_claim": {
      "provider": "kubernetes",
      "data_source": "kubernetes_resources",
      "extra": { "api_version": "v1", "kind": "PersistentVolumeClaim" }
    },
    "resource_quota": {
      "provider": "kubernetes",
      "data_source": "kubernetes_resources",
      "extra": { "api_version": "v1", "kind": "ResourceQuota" }
