{
  "uid": "kxn-postgres",
  "title": "Your cluster — Postgres kxn-pg performance",
  "tags": [
    "kxn",
    "perf",
    "postgres",
    "rtk"
  ],
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Connections in use",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num FROM metrics WHERE resource_type='db_stats' AND metric_name='active_connections' AND time > NOW() - interval '5 minutes' ORDER BY time DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Database size (MB)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num FROM metrics WHERE resource_type='db_stats' AND metric_name='database_size_mb' AND time > NOW() - interval '5 minutes' ORDER BY time DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache hit ratio (%)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num FROM metrics WHERE resource_type='db_stats' AND metric_name='cache_hit_ratio' AND time > NOW() - interval '5 minutes' ORDER BY time DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total tables",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT (SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='public')"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "All db_stats metrics (latest scrape)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT metric_name, COALESCE(value_num::text, value_str) AS value FROM (SELECT DISTINCT ON (metric_name) * FROM metrics WHERE resource_type='db_stats' AND time > NOW() - interval '5 minutes' ORDER BY metric_name, time DESC) x ORDER BY metric_name"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Top 25 tables by size",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT schemaname || '.' || relname AS table, pg_size_pretty(pg_total_relation_size(relid)) AS total_size, n_live_tup AS rows FROM pg_stat_user_tables ORDER BY pg_total_relation_size(relid) DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "db_size + connections over time",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', time) AS time, metric_name AS metric, MAX(value_num) AS value FROM metrics WHERE resource_type='db_stats' AND metric_name IN ('database_size_mb','active_connections','cache_hit_ratio') AND $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    }
  ],
  "editable": true
}