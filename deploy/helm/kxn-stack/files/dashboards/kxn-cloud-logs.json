{
  "uid": "kxn-Your cluster-logs",
  "title": "Your cluster — Logs",
  "tags": [
    "kxn",
    "logs",
    "rtk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total log lines (last 1h)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS total FROM logs WHERE $__timeFilter(time)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors (last 1h)",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS errors FROM logs WHERE $__timeFilter(time) AND level='error'"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Warnings (last 1h)",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS warnings FROM logs WHERE $__timeFilter(time) AND level='warning'"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active pods producing logs",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT tags->>'pod') AS pods FROM logs WHERE time > NOW() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Ingest rate (lines/min, last 5m)",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::float / 5 AS lines_per_min FROM logs WHERE time > NOW() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Lines per minute by namespace",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 16,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', time) AS time, tags->>'namespace' AS metric, COUNT(*) AS value FROM logs WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Errors / warnings per minute",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', time) AS time, level AS metric, COUNT(*) AS value FROM logs WHERE $__timeFilter(time) AND level IN ('error','warning') GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    },
    {
      "id": 20,
      "type": "table",
      "title": "Recent log lines (filtered)",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT time, level, tags->>'namespace' AS namespace, tags->>'pod' AS pod, tags->>'container' AS container, message FROM logs WHERE $__timeFilter(time) ORDER BY time DESC LIMIT 200"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "level"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "namespace"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "pod"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 250
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "container"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "message"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto",
                  "wrapText": true
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    }
  ],
  "editable": true
}