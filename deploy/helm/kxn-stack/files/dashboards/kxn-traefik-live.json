{
  "uid": "kxn-traefik-live",
  "title": "Your cluster — Traefik Live logs",
  "tags": [
    "kxn",
    "live",
    "rtk",
    "traefik"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Lines/s (last 1m)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::float / 60 FROM logs WHERE tags->>'namespace'='traefik' AND time > NOW() - interval '1 minute'"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "JSON access logs / total (last 5m)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FILTER (WHERE message LIKE '{%') || ' / ' || COUNT(*) FROM logs WHERE tags->>'namespace'='traefik' AND time > NOW() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Distinct hosts hit (last 5m)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT (message::jsonb)->>'RequestHost') FROM logs WHERE tags->>'namespace'='traefik' AND message LIKE '{%' AND time > NOW() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Errors 5xx (last 5m)",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM logs WHERE tags->>'namespace'='traefik' AND message LIKE '{%' AND ((message::jsonb)->>'DownstreamStatus')::int >= 500 AND time > NOW() - interval '5 minutes'"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Status code distribution (per minute)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', time) AS time, ((message::jsonb)->>'DownstreamStatus')::text AS metric, COUNT(*) AS value FROM logs WHERE tags->>'namespace'='traefik' AND message LIKE '{%' AND $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    },
    {
      "id": 20,
      "type": "table",
      "title": "Live access log (200 latest)",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 14
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT time, ((message::jsonb)->>'DownstreamStatus')::int AS status, (message::jsonb)->>'RequestMethod' AS method, (message::jsonb)->>'RequestHost' AS host, (message::jsonb)->>'RequestPath' AS path, ((message::jsonb)->>'Duration')::bigint / 1000000 AS duration_ms, (message::jsonb)->>'ClientHost' AS client_lb_ip, (message::jsonb)->>'request_X-Forwarded-For' AS client_real_ip FROM logs WHERE tags->>'namespace'='traefik' AND message LIKE '{%' AND $__timeFilter(time) ORDER BY time DESC LIMIT 200"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "blue",
                      "value": 200
                    },
                    {
                      "color": "yellow",
                      "value": 300
                    },
                    {
                      "color": "orange",
                      "value": 400
                    },
                    {
                      "color": "red",
                      "value": 500
                    }
                  ]
                }
              },
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "duration_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "method"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "host"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 220
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "client_lb_ip"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "client_real_ip"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          }
        ]
      }
    }
  ],
  "editable": true
}