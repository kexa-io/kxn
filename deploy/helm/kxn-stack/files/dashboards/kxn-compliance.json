{
  "uid": "kxn-compliance",
  "title": "Your cluster — Compliance",
  "tags": [
    "compliance",
    "kxn",
    "rtk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Failing rules now",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH last AS (SELECT MAX(created_at) FROM scans) SELECT COUNT(*) AS failing FROM scans s, last l WHERE s.created_at >= l.max - interval '90 seconds' AND s.error = true"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pass rate (last cycle)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH last AS (SELECT MAX(created_at) FROM scans), recent AS (SELECT * FROM scans s, last l WHERE s.created_at >= l.max - interval '90 seconds') SELECT (SUM(CASE WHEN NOT error THEN 1 ELSE 0 END)::float / NULLIF(COUNT(*),0) * 100) AS pct FROM recent"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Targets monitored",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT target) AS targets FROM scans WHERE created_at > NOW() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total rules evaluated (last cycle)",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH last AS (SELECT MAX(created_at) FROM scans) SELECT COUNT(*) AS total FROM scans s, last l WHERE s.created_at >= l.max - interval '90 seconds'"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Pass / Fail rate per target",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', created_at) AS time, target || ' / ' || CASE WHEN error THEN 'fail' ELSE 'pass' END AS metric, COUNT(*) AS value FROM scans WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    },
    {
      "id": 20,
      "type": "table",
      "title": "Top 25 currently failing rules (last cycle)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH last AS (SELECT MAX(created_at) AS max_at FROM scans) SELECT s.target, r.name AS rule_name, r.description AS rule_description, r.level AS severity, COUNT(*) AS instances FROM scans s LEFT JOIN rules r ON s.rule_id = r.id CROSS JOIN last l WHERE s.created_at >= l.max_at - interval '90 seconds' AND s.error = true GROUP BY s.target, r.name, r.description, r.level ORDER BY r.level DESC NULLS LAST, instances DESC LIMIT 25"
        }
      ]
    }
  ],
  "editable": true
}