{
  "uid": "kxn-cluster",
  "title": "Your cluster — Cluster",
  "tags": [
    "kxn",
    "rtk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes ready",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num AS \"ready\" FROM metrics WHERE resource_type='cluster_stats' AND metric_name='nodes_ready' ORDER BY time DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pods running",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num AS \"running\" FROM metrics WHERE resource_type='cluster_stats' AND metric_name='pods_running' ORDER BY time DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pods failed",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num AS \"failed\" FROM metrics WHERE resource_type='cluster_stats' AND metric_name='pods_failed' ORDER BY time DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Deployments unavailable",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num AS \"unavailable\" FROM metrics WHERE resource_type='cluster_stats' AND metric_name='deployments_unavailable' ORDER BY time DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Pod restarts (cluster total)",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num AS \"restarts\" FROM metrics WHERE resource_type='cluster_stats' AND metric_name='total_restarts' ORDER BY time DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Warning events",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value_num AS \"warnings\" FROM metrics WHERE resource_type='cluster_stats' AND metric_name='warning_events' ORDER BY time DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Pods running / pending / failed",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time, metric_name AS metric, value_num AS value FROM metrics WHERE $__timeFilter(time) AND resource_type='cluster_stats' AND metric_name IN ('pods_running','pods_pending','pods_failed') ORDER BY time"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Nodes ready vs total",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time, metric_name AS metric, value_num AS value FROM metrics WHERE $__timeFilter(time) AND resource_type='cluster_stats' AND metric_name IN ('nodes_ready','nodes_not_ready','nodes_total') ORDER BY time"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Cluster CPU (sum of node millicores)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time, 'cpu_millicores' AS metric, SUM(value_num) AS value FROM metrics WHERE $__timeFilter(time) AND resource_type='node_metrics' AND metric_name='cpu_millicores' GROUP BY time ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Cluster memory (sum of node MiB)",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time, 'memory_mib' AS metric, SUM(value_num) AS value FROM metrics WHERE $__timeFilter(time) AND resource_type='node_metrics' AND metric_name='memory_mib' GROUP BY time ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "mbytes"
        }
      }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "kxn scan results — passed vs failed (per target)",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', created_at) AS time, target || ' / ' || CASE WHEN error THEN 'failed' ELSE 'passed' END AS metric, COUNT(*) AS value FROM scans WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    }
  ],
  "editable": true
}