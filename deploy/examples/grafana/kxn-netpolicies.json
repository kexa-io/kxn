{
  "uid": "kxn-netpolicies",
  "title": "Your cluster — Network Policies coverage",
  "tags": [
    "kxn",
    "network",
    "rtk",
    "security"
  ],
  "schemaVersion": 39,
  "refresh": "5m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Namespaces total",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM (SELECT DISTINCT ON (namespace) * FROM netpol_coverage ORDER BY namespace, time DESC) x"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Without any NetworkPolicy",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM (SELECT DISTINCT ON (namespace) * FROM netpol_coverage ORDER BY namespace, time DESC) x WHERE netpol_count = 0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Without default-deny ingress",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM (SELECT DISTINCT ON (namespace) * FROM netpol_coverage ORDER BY namespace, time DESC) x WHERE NOT has_default_deny"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "With at least 1 NP",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM (SELECT DISTINCT ON (namespace) * FROM netpol_coverage ORDER BY namespace, time DESC) x WHERE netpol_count >= 1"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Per-namespace coverage",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 14
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT namespace, netpol_count, has_default_deny FROM (SELECT DISTINCT ON (namespace) * FROM netpol_coverage ORDER BY namespace, time DESC) x ORDER BY netpol_count ASC, namespace ASC"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "netpol_count"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "has_default_deny"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "color": "green",
                        "text": "yes"
                      },
                      "false": {
                        "color": "red",
                        "text": "NO"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "editable": true
}