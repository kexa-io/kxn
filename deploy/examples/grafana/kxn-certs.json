{
  "uid": "kxn-certs",
  "title": "Your cluster — TLS Certificates expiration",
  "tags": [
    "certs",
    "kxn",
    "rtk",
    "tls"
  ],
  "schemaVersion": 39,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Expiring < 14 days",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT (namespace, secret_name)) FROM (SELECT DISTINCT ON (namespace, secret_name) * FROM tls_certs ORDER BY namespace, secret_name, time DESC) x WHERE days_left BETWEEN 0 AND 14"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Expiring < 30 days",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT (namespace, secret_name)) FROM (SELECT DISTINCT ON (namespace, secret_name) * FROM tls_certs ORDER BY namespace, secret_name, time DESC) x WHERE days_left BETWEEN 0 AND 30"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Expired",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT (namespace, secret_name)) FROM (SELECT DISTINCT ON (namespace, secret_name) * FROM tls_certs ORDER BY namespace, secret_name, time DESC) x WHERE days_left < 0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total certs tracked",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT (namespace, secret_name)) FROM (SELECT DISTINCT ON (namespace, secret_name) * FROM tls_certs ORDER BY namespace, secret_name, time DESC) x"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "All TLS certificates — sorted by expiration",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "kxn-pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT namespace, secret_name, common_name, substring(san, 1, 80) AS san, issuer, not_after::date AS expires_on, days_left FROM (SELECT DISTINCT ON (namespace, secret_name) * FROM tls_certs ORDER BY namespace, secret_name, time DESC) x ORDER BY days_left ASC NULLS LAST"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "days_left"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 14
                    },
                    {
                      "color": "yellow",
                      "value": 30
                    },
                    {
                      "color": "green",
                      "value": 60
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "editable": true
}